{
  "http_host": "127.0.0.1",
  "http_port": 8768,
  "public_base_url": "http://127.0.0.1:8768",
  "database_path": "~/.local/share/historian/historian.db",
  "resolver_backend": "openai_compatible",
  "resolver_base_url": "http://localhost:11434/v1",
  "resolver_model": "gemma4:latest",
  "resolver_api_key": "",
  "resolver_include_reasoning": false,
  "debug_enabled": false,
  "debug_log_path": "/tmp/historian-debug.log",
  "resolver_debug_log_path": "/tmp/historian-resolver.log",
  "cli_token_path": "~/.config/historian/cli-token",
  "request_timeout_seconds": 60.0,
  "resolver_max_retries": 3,
  "verify_tls": true,
  "log_level": "INFO",
  "max_search_results": 50,
  "max_evidence_characters": 32000,
  "max_regex_patterns": 3,
  "max_regex_length": 256,
  "max_regex_candidates": 5000,
  "regex_timeout_seconds": 0.05,
  "max_event_bytes": 1048576,
  "max_batch_events": 100
}
